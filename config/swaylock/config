# Konfigurasi Swaylock
# Simpan file ini di: ~/.config/swaylock/config

# Nonaktifkan tampilan default
ignore-empty-password

# Sembunyikan cursor
hide-keyboard-layout
indicator-caps-lock

# Warna Background
color=1e1e2e

# Indikator
indicator
indicator-radius=120
indicator-thickness=12

# Warna Ring Indikator
ring-color=313244
ring-clear-color=89b4fa
ring-caps-lock-color=f9e2af
ring-ver-color=a6e3a1
ring-wrong-color=f38ba8

# Warna Interior Ring
inside-color=1e1e2e
inside-clear-color=1e1e2e
inside-caps-lock-color=1e1e2e
inside-ver-color=1e1e2e
inside-wrong-color=1e1e2e

# Warna Garis
line-color=00000000
line-clear-color=00000000
line-caps-lock-color=00000000
line-ver-color=00000000
line-wrong-color=00000000

# Warna Separator
separator-color=00000000

# Warna Teks
text-color=cdd6f4
text-clear-color=1e1e2e
text-caps-lock-color=1e1e2e
text-ver-color=1e1e2e
text-wrong-color=1e1e2e

# Key Highlight
key-hl-color=89b4fa
bs-hl-color=f38ba8

# Caps Lock Warning
caps-lock-key-hl-color=f9e2af
caps-lock-bs-hl-color=f38ba8

# Layout dan Font
font=Sans
font-size=24

# Tampilkan waktu dan tanggal
clock
timestr=%H:%M
datestr=%A, %d %B %Y

# Indikator posisi (tengah layar)
indicator-idle-visible

# Fade in effect
fade-in=0.3

# NONAKTIFKAN grace period - harus input password
# grace=2
# grace-no-mouse
# grace-no-touch

# Screenshot blur (jika menggunakan opsi -i dengan screenshot)
# effect-blur=7x5
# effect-pixelate=5

# Show indicator even when idle
show-keyboard-layout
show-failed-attempts
