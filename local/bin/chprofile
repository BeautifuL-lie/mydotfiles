#!/bin/bash

current=$(powerprofilesctl get)

asusctl profile -n > /dev/null 2>&1

case "$current" in
    performance)
        next="balanced"
        ;;
    balanced)
        next="power-saver"
        ;;
    power-saver)
        next="performance"
        ;;
    *)
        next="balanced"
        ;;
esac

powerprofilesctl set "$next"
profile="${next^}"
swayosd-client --custom-message "$profile"
