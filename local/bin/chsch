#!/usr/bin/env bash

mode=$1
wallpaper=$(cat "$HOME/.wallpaper")
custom_color=$(cat "$HOME/.custom-color")

if [ "$mode" = "dark" ]; then
	if [ -f ~/.custom-color ]; then
		if [ "$custom_color" != "monochrome" ]; then
			matugen color hex "$custom_color" -m dark
		else
			matugen color hex "#000000" -m dark -t scheme-monochrome
		fi
	else
		matugen image "$wallpaper" -m dark 
	fi
	echo "dark" > ~/.mode
	gsettings set org.gnome.desktop.interface icon-theme 'Papirus-Dark'
	swaync-client -cp
	swaync-client -op
elif [ "$mode" = "light" ]; then
	if [ -f ~/.custom-color ]; then
		if [ "$custom_color" != "monochrome" ]; then
			matugen color hex "$custom_color" -m light
		else
			matugen color hex "#000000" -m light -t scheme-monochrome
		fi
	else
		matugen image "$wallpaper" -m light 
	fi
  	echo "light" > ~/.mode
	gsettings set org.gnome.desktop.interface icon-theme 'Papirus-Light'
	swaync-client -cp 
	swaync-client -op 
else
  	echo "Invalid argument"
fi
