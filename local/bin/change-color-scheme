#!/usr/bin/env bash

mode=$(cat "$HOME/.mode")
wallpaper=$(cat "$HOME/.wallpaper")
customcolor="$HOME/.custom-color"

# Fungsi cek HEX
is_hex() {
    [[ "$1" =~ ^#[A-Fa-f0-9]{6}$ ]]
}

# --- Jika tidak ada argumen: buka rofi input ---
if [ $# -eq 0 ]; then
  swaync-client -cp
  color=$(rofi -dmenu -p "HEX color / monochrome")

  # Jika user cancel
  if [ -z "$color" ]; then
    exit 1
  fi

  # Jika monochrome
  if [ "$color" = "monochrome" ]; then
    matugen color hex "#000000" -m "$mode" -t scheme-monochrome
    echo "monochrome" > "$customcolor"
    exit 0
  fi

  # Jika HEX valid
  if is_hex "$color"; then
    matugen color hex "$color" -m "$mode"
    echo "$color" > "$customcolor"
    exit 0
  fi

  # Invalid input
  notify-send "Input tidak valid" "Gunakan format #RRGGBB atau 'monochrome'"
  exit 1
fi

# --- Mode monochrome via argumen ---
if [ "$1" = "monochrome" ]; then
  matugen color hex "#000000" -m "$mode" -t scheme-monochrome
  echo "monochrome" > "$customcolor"
else
  echo "Argumen invalid"
fi
